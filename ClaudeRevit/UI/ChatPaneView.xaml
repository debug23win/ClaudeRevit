<UserControl x:Class="ClaudeRevit.UI.ChatPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ClaudeRevit.UI"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="380"
             FontFamily="Segoe UI" FontSize="13">
    <UserControl.Resources>
        <Style x:Key="SelectableMessageRichTextBox" TargetType="RichTextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsDocumentEnabled" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Cursor" Value="IBeam" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" x:Name="ModelPicker"
                          Width="190" Height="24" VerticalContentAlignment="Center"
                          SelectionChanged="ModelPicker_SelectionChanged">
                    <ComboBoxItem Tag="auto" IsSelected="True">Auto (cost-optimized)</ComboBoxItem>
                    <ComboBoxItem Tag="sonnet-5">Sonnet 5 (default)</ComboBoxItem>
                    <ComboBoxItem Tag="opus-4-8">Opus 4.8 (smart)</ComboBoxItem>
                    <ComboBoxItem Tag="fable-5">Fable 5 (smartest)</ComboBoxItem>
                    <ComboBoxItem Tag="haiku-4-5">Haiku 4.5 (fastest)</ComboBoxItem>
                    <ComboBoxItem Tag="sonnet-4-6">Sonnet 4.6</ComboBoxItem>
                    <ComboBoxItem Tag="opus-4-7">Opus 4.7</ComboBoxItem>
                    <ComboBoxItem Tag="claudecode">Claude Code (subscription)</ComboBoxItem>
                    <ComboBoxItem Tag="alt" x:Name="AltModelItem">Alt model (set up in ⚙)</ComboBoxItem>
                </ComboBox>
                <CheckBox Grid.Column="1" x:Name="SubscriptionBox" Content="Subscription"
                          VerticalAlignment="Center" Margin="10,0,0,0"
                          Checked="SubscriptionBox_Changed" Unchecked="SubscriptionBox_Changed"
                          ToolTip="Run the selected model through the Claude Code CLI on your Pro/Max subscription (via the MCP server) instead of the pay-per-token API — zero API cost. Needs the Claude Code CLI installed. Note: the Auto advisor/haiku→opus escalation does not apply here — Claude Code runs its own loop with the one chosen model (Auto = its default model)." />
                <Button Grid.Column="2" x:Name="ClearButton"
                        Content="Clear" Height="24" Padding="10,0" Margin="0,0,4,0"
                        Click="ClearButton_Click"
                        ToolTip="Clear the current conversation." />
                <Button Grid.Column="3" x:Name="RunToolButton"
                        Content="▶" Height="24" Width="28" FontSize="12" Margin="0,0,4,0"
                        Click="RunToolButton_Click"
                        ToolTip="Run a saved custom tool directly (no AI, 0 tokens)." />
                <Button Grid.Column="4" x:Name="BenchmarkButton"
                        Content="📊" Height="24" Width="28" FontSize="12" Margin="0,0,4,0"
                        Click="BenchmarkButton_Click"
                        ToolTip="Model benchmark — run graded tasks and compare models (time, tokens, pass rate)." />
                <Button Grid.Column="5" x:Name="SettingsButton"
                        Content="⚙" Height="24" Width="28" FontSize="14"
                        Click="SettingsButton_Click"
                        ToolTip="Settings — set or change your API key." />
            </Grid>
        </Border>

        <!-- ListBox, not ItemsControl-in-a-ScrollViewer: the latter gives items infinite
             height so WPF realizes EVERY message at once (hundreds of heavy RichTextBox
             visual trees), which makes every Revit layout pass — even a tab switch — crawl
             once the conversation grows. A virtualizing ListBox realizes only the visible
             rows (recycled, pixel-scrolled), so cost is bounded by the viewport, not the
             history length. Selection chrome is stripped so bubbles look identical and the
             RichTextBox keeps its own text selection. -->
        <ListBox Grid.Row="1" x:Name="MessagesList" ItemsSource="{Binding Messages}"
                 BorderThickness="0" Background="Transparent" Padding="8"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <!-- Not focusable + bare template = no blue selection highlight and no
                         focus stealing from the RichTextBox the user selects text in. -->
                    <Setter Property="Focusable" Value="False" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="10,8" CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFFFFF" />
                                    <Setter Property="BorderBrush" Value="#E0E0E0" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                            <Setter Property="Background" Value="#E3F2FD" />
                                            <Setter Property="BorderBrush" Value="#BBDEFB" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="tool">
                                            <Setter Property="Background" Value="#FFF8E1" />
                                            <Setter Property="BorderBrush" Value="#FFD54F" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Role}" Value="tool" />
                                                <Condition Binding="{Binding IsError}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#FFEBEE" />
                                            <Setter Property="BorderBrush" Value="#EF9A9A" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding RoleDisplay}"
                                           FontWeight="SemiBold" FontSize="11"
                                           Foreground="#555" Margin="0,0,0,3" />
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <RichTextBox Style="{StaticResource SelectableMessageRichTextBox}"
                                                                     local:PlainTextProp.Text="{Binding Text}" />
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Role}" Value="assistant">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <RichTextBox Style="{StaticResource SelectableMessageRichTextBox}"
                                                                             local:MarkdownProps.Markdown="{Binding Text}" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Role}" Value="tool">
                                                    <Setter Property="ContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <RichTextBox Style="{StaticResource SelectableMessageRichTextBox}"
                                                                             FontFamily="Consolas" FontSize="12"
                                                                             local:ElementIdLinker.Text="{Binding Text}" />
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" x:Name="SelectionPillBorder"
                Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="0,1,0,1"
                Padding="10,4" Visibility="Collapsed">
            <TextBlock x:Name="SelectionPillText" FontSize="11" Foreground="#2E7D32" />
        </Border>

        <Grid Grid.Row="3" Margin="10,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock x:Name="StatusText" Foreground="#888" FontSize="11" VerticalAlignment="Center" />
                <TextBlock x:Name="UpdateNotice" FontSize="11" Foreground="#1565C0" Margin="8,0,0,0"
                           VerticalAlignment="Center" Cursor="Hand" Visibility="Collapsed"
                           TextDecorations="Underline" MouseLeftButtonUp="UpdateNotice_Click"
                           ToolTip="A newer version is on GitHub — click to download the installer." />
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="UsageText"
                       Foreground="#888" FontSize="11"
                       FontFamily="Consolas" />
        </Grid>

        <Grid Grid.Row="4" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="AttachButton"
                    Content="📎" Width="34" MinHeight="60" FontSize="15" Margin="0,0,6,0"
                    Click="AttachButton_Click" VerticalAlignment="Stretch"
                    ToolTip="Attach an image for the model to see (needs a vision-capable model)." />
            <TextBox x:Name="InputBox" Grid.Column="1"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="60" MaxHeight="180"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8" BorderBrush="#CCC"
                     ToolTip="Enter — send, Shift+Enter — new line"
                     PreviewKeyDown="InputBox_PreviewKeyDown" />
            <Button Grid.Column="2" x:Name="SendButton"
                    Content="Send" Width="72" Margin="6,0,0,0"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</UserControl>
