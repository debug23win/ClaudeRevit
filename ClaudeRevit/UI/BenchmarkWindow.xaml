<Window x:Class="ClaudeRevit.UI.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Revit — Model benchmark"
        Width="780" Height="620"
        WindowStartupLocation="CenterOwner"
        MinWidth="620" MinHeight="420"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="13">
    <DockPanel Margin="14">

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="ModelBox" Width="150" Height="26" VerticalContentAlignment="Center">
                <ComboBoxItem Tag="auto" IsSelected="True">Auto (as configured)</ComboBoxItem>
                <ComboBoxItem Tag="sonnet-5">Sonnet 5</ComboBoxItem>
                <ComboBoxItem Tag="opus-4-8">Opus 4.8</ComboBoxItem>
                <ComboBoxItem Tag="fable-5">Fable 5</ComboBoxItem>
                <ComboBoxItem Tag="haiku-4-5">Haiku 4.5</ComboBoxItem>
                <ComboBoxItem Tag="alt">Alt model</ComboBoxItem>
                <ComboBoxItem Tag="claudecode">Claude Code (MCP / subscription)</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Tasks:" VerticalAlignment="Center" Margin="12,0,8,0" />
            <ComboBox x:Name="TaskSetBox" Width="150" Height="26" VerticalContentAlignment="Center"
                      ToolTip="Run a subset to save tokens — you rarely need all 14 every time.">
                <ComboBoxItem Tag="all" IsSelected="True">All (14)</ComboBoxItem>
                <ComboBoxItem Tag="basic">Basics only (7)</ComboBoxItem>
                <ComboBoxItem Tag="composite">Composite L1–L4</ComboBoxItem>
                <ComboBoxItem Tag="domain">Domain: rebar &amp; steel</ComboBoxItem>
                <ComboBoxItem Tag="hard">Hard discriminators (L3,L4,R,S)</ComboBoxItem>
            </ComboBox>
            <Button x:Name="RunButton" Content="Run benchmark" Width="120" Height="26" Margin="16,0,0,0"
                    Click="RunButton_Click" />
            <Button x:Name="CancelButton" Content="Stop" Width="70" Height="26" Margin="8,0,0,0"
                    Click="CancelButton_Click" IsEnabled="False" />
            <CheckBox x:Name="ResetBox" Content="Reset model between tasks" IsChecked="True"
                      VerticalAlignment="Center" Margin="16,0,0,0"
                      ToolTip="Delete each task's elements after grading, so every task starts from the same clean baseline (fair comparison). Uncheck to keep everything and inspect the result." />
            <TextBlock Text="Stop task after" VerticalAlignment="Center" Margin="16,0,4,0" />
            <TextBox x:Name="MaxRoundsBox" Text="15" Width="34" Height="24" VerticalContentAlignment="Center"
                     ToolTip="Give up on a task after this many tool rounds and grade what it built (0 = no limit)." />
            <TextBlock Text="rounds or" VerticalAlignment="Center" Margin="4,0,4,0" />
            <TextBox x:Name="MaxMinutesBox" Text="5" Width="34" Height="24" VerticalContentAlignment="Center"
                     ToolTip="…or after this many minutes (0 = no limit)." />
            <TextBlock Text="min" VerticalAlignment="Center" Margin="4,0,0,0" />
            <CheckBox x:Name="JudgeViaCCBox" Content="Judge on subscription" IsChecked="True"
                      VerticalAlignment="Center" Margin="16,0,0,0"
                      ToolTip="Grade with the Claude Code CLI (your subscription) instead of the Opus 4.8 API, so the benchmark costs nothing on the API. The judge still grades only from the objective before/after probe. Needs the Claude Code CLI installed." />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" FontSize="11" Foreground="#B26A00" Margin="0,0,0,8"
                   Text="Runs real modelling in the ACTIVE document — open a scratch/empty project first. Each task is one undo step. Grading uses an impartial fixed judge (Opus 4.8), so an Anthropic API key is required even when testing an alternative model. Results are appended to benchmark_results.jsonl in %AppData%\ClaudeRevit." />

        <Border DockPanel.Dock="Top" Background="#EEF4FF" BorderBrush="#CFE0FF" BorderThickness="1"
                Padding="8,5" Margin="0,0,0,8" x:Name="NowPanel" Visibility="Collapsed">
            <TextBlock x:Name="NowText" FontFamily="Consolas" FontSize="12"
                       Text="idle" TextTrimming="CharacterEllipsis"
                       ToolTip="The clock keeps ticking while it works — if it freezes for a long time, Revit is busy on a heavy operation." />
        </Border>

        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontWeight="SemiBold" />
            <Button x:Name="CloseButton" Content="Close" Width="80" Height="26" HorizontalAlignment="Right"
                    Click="CloseButton_Click" />
        </Grid>

        <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeaderWidth="0" FontSize="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Task" Binding="{Binding TaskId}" Width="46" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="150" />
                <DataGridTextColumn Header="✓/✗" Binding="{Binding Verdict}" Width="40" />
                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="50" />
                <DataGridTextColumn Header="Rounds" Binding="{Binding Rounds}" Width="60" />
                <DataGridTextColumn Header="Tokens" Binding="{Binding Tokens}" Width="80" />
                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="60" />
                <DataGridTextColumn Header="Judge reason" Binding="{Binding Reason}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
